setcolor

setcolor

setup() {  
  # Update the Go module path references in all files
  # then run go mod tidy
  read -r -p "Go module path: " gomodpath
  ESCAPED_REPLACE=$(printf '%s\n' "${gomodpath}" | sed -e 's/[\/&]/\\&/g')
  
  # shellcheck disable=SC2013
  for file in $(grep -rl --exclude-dir=.git \
                  --exclude-dir=services/dashboard \
                  --exclude=shMakefile \
                  "github.com/totomz/template-burrito" .); do
    echo "Patching ${file}"
    sed -ibak "s/github.com\/totomz\/template-burrito/${ESCAPED_REPLACE}/" "${file}"    
  done
  
  find . -name '*bak' -delete
  
  # Run go mod tidy in all go services
  # shellcheck disable=SC2044
  for p in $(find . -name go.mod); do
    path=${p%/*}
    echo "go mod: ${path}"
    cd "${path}" && go mod tidy && cd - || exit
  done
  
}
